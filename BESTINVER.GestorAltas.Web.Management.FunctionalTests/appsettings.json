{
  "AppSettings": {
    "ReplaySignatureLife": 1,
    "ApiWebPrivadaBaseAddress": "https://apidev.dev.bestinver.es/",
    "BestinverWeb": "",
    "MaxPdfUploadSize": 5242880,
    "AppName": "Bestinver.backoffice.App",
    "EnableAAD": false,
    "WarningMailTeckDaysRemaining": 2,
    "MaxClientsToGenerate": 50,
    "UrlSharedFolder": ""
  },
  "RequestLocalizationOptions": {
    "DefaultRequestCulture": {
      "Culture": "es-ES",
      "UICulture": "es-ES"
    },
    "SupportedCultures": [ "es-ES", "en-US", "en-GB" ],
    "SupportedUICultures": [ "es-ES", "en-US", "en-GB" ],
    "RequestCultureProviders": [
      {
        "Type": "CookieRequestCultureProvider",
        "Options": {
          "CookieName": ".AspNetCore.Culture"
        }
      }
    ]
  },
  // The ClientSecret has to be in users secret
  "IdentityServerSection": {
    "Authority": "https://clientesdev.dev.bestinver.es/login/",
    "ClientId": "openIdKabelMiddleoffice",
    "Scopes": "testsAPI requestsAPI alertsAPI dashboardsAPI carterasAPI customersAPI customizationsAPI usersAPI operationsAPI productsAPI filesAPI signupAPI signaturesAPI sendemailAPI remediationAPI amlAPI portfoliosAPI movementsAPI prospectsAPI consentsAPI newslettersAPI generalParametersAPI rubricaeAPI"
  }
}