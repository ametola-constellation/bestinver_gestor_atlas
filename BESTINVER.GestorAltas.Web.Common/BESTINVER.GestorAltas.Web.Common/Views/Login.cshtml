@model BESTINVER.GestorAltas.Web.Common.Models.LoginViewModel
@Html.AntiForgeryToken()

<style>
    @@font-face {
       font-family: 'Acciona-Regular';
       src: url('data:application/font-woff;base64,') format('woff');
     }

    * {
        box-sizing: border-box;
        font-family: 'Acciona-Regular', Tahoma, Geneva, Verdana, sans-serif;
    }

    body {
        margin: 0;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        background-color: #f4f4f9;
    }

    .content {
        min-height: calc(100vh - 173px);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

    #login_main {
        background-color: #ffffff;
        width: 80vw;
        max-width: 400px;
        height: 300px;
        padding: 40px 30px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
        border-radius: 10px;
        text-align: center;
        margin: auto;
    }

        #login_main img {
            width: 160px;
            margin-bottom: 20px;
        }

        #login_main h1 {
            font-size: 24px;
            color: #333;
            margin-bottom: 20px;
            font-weight: 600;
        }

    .li-login {
        width: 100%;
    }

    .azure-login-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background-color: #b59971;
        color: #ffffff;
        font-size: 16px;
        font-weight: bold;
        padding: 12px 20px;
        border-radius: 8px;
        text-decoration: none;
        transition: box-shadow 0.3s, background-color 0.3s;
        width: 100%;
        margin: 20px 0;
        border: 1px solid #b59971;
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
    }

        .azure-login-btn:hover {
            background-color: #9e7c5c;
            border: 1px solid #9e7c5c;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
            color: #ffffff;
            text-decoration: none;
        }

    .error {
        color: #d9534f;
        font-size: 14px;
        margin-top: 10px;
    }

    .alert {
        color: #856404;
        background-color: #fff3cd;
        border-color: #ffeeba;
        padding: 10px;
        border-radius: 5px;
        margin-top: 15px;
    }
</style>

@if (Model.Redirect)

{
    <script>
        @Html.Raw($"document.location = '{Model.ReturnUrl}'")
    </script>
}

<div id="login_main">
    <img src="https://www.bestinver.es/wp-content/themes/bstnvr/images/logo-bestinver.svg" alt="Logo Bestinver">
    <h1>Inicia sesión con tu cuenta corporativa</h1>
    <form method="post">
        <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
        @if (Model.VisibleExternalProviders.Any())

        {
            <ul class="list-inline">
                @foreach (var provider in Model.VisibleExternalProviders)

                {
                    <li class="list-inline-item li-login">
                        <a class="azure-login-btn"
                           asp-controller="ExternalLogin"
                           asp-action="Index"
                           asp-route-scheme="@provider.AuthenticationScheme"
                           asp-route-returnUrl="@Model.ReturnUrl">
                            INICIAR SESIÓN
                        </a>
                    </li>
                }
            </ul>
        }
        @if (Model.Errors != null)

        {

            foreach (var item in Model.Errors.ToList())

            {
                <div><span class="error">@item</span></div>
            }

        }
        @if (!Model.EnableLocalLogin && !Model.VisibleExternalProviders.Any())

        {
            <div class="alert alert-warning">
                @Html.Raw("Invalid Login Request")
            </div>
        }
    </form>
</div>

