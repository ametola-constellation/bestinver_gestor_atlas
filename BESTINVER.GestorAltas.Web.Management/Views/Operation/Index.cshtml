<div id='TitularesModal' class='modal fade' role="dialog" aria-labelledby="TitularesLabel" data-url='@Url.Action("OperationDetail")'></div>
<div id='ObservacionesModal' class='modal fade' role="dialog" aria-labelledby="ObservacionesLabel" data-url='@Url.Action("StatusDetail")'></div>
<div id='ShowInfoModal' class='modal fade' role="dialog" aria-labelledby="ShowInfoLabel" data-url='@Url.Action("ShowInfo")'></div>
<div id='ShowDocumentsModal' class='modal fade' role="dialog" aria-labelledby="ShowDocumentsLabel" data-url='@Url.Action("ShowDocuments")'></div>
<div id='ShowSignatureStatusModal' class='modal fade' role="dialog" aria-labelledby="ShowSignatureStatusLabel" data-url='@Url.Action("ShowSignatureStatus")'></div>


<div id='CancelOperationModal' class='modal fade' role="dialog" aria-labelledby="CancelOperationLabel" data-url='@Url.Action("OperationCancelDetail")'></div>

@section Scripts {

    <environment include="Development">

        <script src="~/js/operation.js" asp-append-version="true"></script>
    </environment>

    <environment exclude="Development">
        <script src="~/js/operation.min.js" asp-append-version="true"></script>
    </environment>
}