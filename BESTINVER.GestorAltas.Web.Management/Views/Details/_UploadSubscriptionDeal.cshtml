@model BESTINVER.GestorAltas.Web.Management.Models.Details.UploadSubscriptionDealModel


<div id='uploadSubscriptionDealModal' class='modal fade' role="dialog" aria-labelledby="uploadSubscriptionDealLabel">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <form asp-action="UploadSubscriptionDeal" asp-controller="Details" method="post" enctype="multipart/form-data">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                    <h4 class="modal-title" id="cotitularLabel">Adjuntar Acuerdo de suscripcion Firmado</h4>
                </div>
                <div class="modal-body">
                    <input asp-for="RequestId" type="hidden" id="RequestId" />
                    <input asp-for="DNI" type="hidden" id="DNI" />
                    <input asp-for="FileName" type="hidden" id="FileName" />
                    <div class="row">
                        <div class="col-md-6">
                            <span>Fecha de la firma del acuerdo</span>
                        </div>
                        <div class="col-md-6">
                            <div class="input-group" style="margin: 5px">
                                <input asp-for="SignDate" class="form-control" type="date" id="SignDealSignDate" /></div>
                            </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6"> 
                            <span>Acuerdo de Suscripcion</span>
                        </div>
                        <div class="col-md-6">
                                <div class="input-group" style="margin: 5px">
                                    <input type="text" style="display:none" />
                                    <input asp-for="File" class="form-control" type="file" id="SignDealUploadFile" name="File" accept="application/pdf" />
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-outline-success" id="SignDealUploadFileButton" disabled>
                        <span class="mr-2 fas fa-cloud-upload-alt"></span>Subir <i class="fas fa-spinner fa-spin hide" id="spinner"></i>
                    </button>
                    <button type="button" class="btn btn-outline-secondary" data-dismiss="modal">Cerrar</button>
                </div>
            </form>
        </div>
    </div>
</div>