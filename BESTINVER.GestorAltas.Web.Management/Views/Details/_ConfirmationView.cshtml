@{
    var idRequest = ViewBag.IdRequest;
    var confirmationType = ViewBag.ConfirmationType;
}
<div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
        @if (confirmationType == "Cancel")
        {
            <div class="modal-header">
                <h4 class="modal-title">Confirmación cancelar operación periódica</h4>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
            </div>
            <div class="modal-body">
                ¿Estás seguro de cancelar la operación periódica con ID: <b>@idRequest</b>?
            </div>
            <div class="modal-footer">
                <button type="button" data-dismiss="modal" class="btn btn-default" id="exit">Cerrar</button>
                <button type="button" data-dismiss="modal" class="btn btn-danger" id="confirmButton"
                        data-requestid="@idRequest" data-url="@Url.Action("Cancel", "Details" )">
                    Cancelar operación
                </button>
            </div>
        }
        else if (confirmationType == "LinkForCancel")
        {
            <div class="modal-header">
                <h4 class="modal-title">Confirmación enviar link para cancelar operación periódica</h4>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
            </div>
            <div class="modal-body">
                ¿Estás seguro de enviar el link para cancelar la operación periódica con ID: <b>@idRequest</b>?
            </div>
            <div class="modal-footer">
                <button type="button" data-dismiss="modal" class="btn btn-default" id="exit">Cerrar</button>
                <button type="button" data-dismiss="modal" class="btn btn-danger" id="confirmButton"
                        data-requestid="@idRequest" data-url="@Url.Action("SendLinkForCancel", "Details")">
                    Enviar link de cancelación
                </button>
            </div>
        }
        else
        {
            <div class="modal-header">
                <h4 class="modal-title">Creación nueva suscripción periódica</h4>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
            </div>
            <div class="modal-body">
                Para iniciar la suscripción periódica, asegúrate de haber subido la documentación a la VPN
            </div>
            <div class="modal-footer">
                <button type="button" data-dismiss="modal" class="btn btn-default" id="exit">Cerrar</button>
                <button type="button" data-dismiss="modal" class="btn btn-success" id="confirmButton"
                        data-requestid="@idRequest" data-url="@Url.Action("ManualStart", "Details")">
                    Subida documentación
                </button>
            </div>
        }
    </div>
</div>
