@model CancelRequestModel

<script type="text/javascript">
    $(document).on('change', '.cancelDialog select', function () {
        var value = $(this).val();
        $('#cancel-other-comments').addClass('hide');

        if (value == 'Otros motivos') {
            $('#cancel-other-comments').removeClass('hide');
        }
    });
</script>

<!-- Modal -->
<div class="modal fade" id="cancel-request" tabindex="-1" role="dialog" aria-labelledby="cancleRequestLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">

                <h5 class="modal-title" id="cancleRequestLabel">Esta acción hará que la solicitud quede Cancelada. Para confirmar introduzca el motivo de cancelación</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <div class="modal-body cancelDialog">

                <form asp-controller="Details" asp-action="CancelRequestValidation" method="post">
                    <input type="hidden" asp-for="RequestId" />

                    <div class="row">
                        <div class="form-group col-md-6">
                            <label asp-for="Comments"></label>
                            <select asp-for="Comments" asp-items="@Model.Reasons" class="form-control" id="reason-combo">
                                <option value="" hidden disabled selected>Seleccione una opción</option>
                            </select>
                            <span asp-validation-for="Comments" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row hide" id="cancel-other-comments" >
                        <div class="form-group col-md-12">
                            <label asp-for="OtherComments"></label>
                            <textarea asp-for="OtherComments" cols="10" rows="5"  class="form-control col-md-12"></textarea>
                        </div>
                    </div>

                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-dismiss="modal">Cancelar</button>
                <button type="button" data-save="modal" class="btn btn-primary">OK</button>
            </div>
        </div>
    </div>
</div>
<partial name="_ValidationScriptsPartial" />