@model RequestStatusModel

<div id='statusInfoModal-@Model.Id' class='modal fade' role="dialog" aria-labelledby="statusInfoModal">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title" id="cotitularLabel">Información adicional</h4>

                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
              
                <div class="row">
                    <div class="form-group col-md-3">
                        <label asp-for="IDRequestFriendly"></label>
                        <input asp-for="IDRequestFriendly" class="form-control" disabled />
                    </div>
                    <div class="form-group col-md-3">
                        <label asp-for="StatusName"></label>
                        <input asp-for="StatusName" class="form-control" disabled />
                    </div>
                    <div class="form-group col-md-3">
                        <label asp-for="Responsible"></label>
                        <input asp-for="Responsible" class="form-control" disabled />
                    </div>
                    <div class="form-group col-md-3">
                        <label asp-for="StartDate"></label>
                        <input class="form-control" disabled
                               data-datetime="@DateTime.SpecifyKind(Model.StartDate, DateTimeKind.Utc).ToString("o")" />
                    </div>
                    <div class="form-group col-md-12">
                        <label asp-for="StatusDescription"></label>
                        <input asp-for="StatusDescription" class="form-control col-md-12" disabled />
                    </div>
                    <div class="form-group col-md-12">
                        <label asp-for="Comments"></label>
                        <textarea asp-for="Comments" class="form-control col-md-12" disabled cols="3"></textarea>
                    </div>
                </div>
                   
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>



