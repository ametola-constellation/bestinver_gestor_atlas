<div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content">
        <div class="modal-header">
            <h4 class="modal-title">Crear Nueva Subscripción FCR - 1 de 2</h4>
            <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
        </div>
        <div class="modal-body">
            <div id="searchClient">
                <label>Introduzca DNI de la persona que deseas buscar las cuentas disponibles:</label>
                <br />
                <input id="dniSearch" type="search" />
                <button id="btnSearchClient" type="button" class="btn btn-primary">Buscar</button>
            </div>
            <div id="dniError" class="margin15" hidden></div>
            <div id="resultSearch" class="row"></div>
            <table id="tblResultAccounts" class="datatable table striped hovered cell-hovered border bordered d-none" action-url="@Url.Action("ShowCreateNewSubscriptionFCR", "FCRFunds")">
                <thead><tr><th>Cuenta</th><th>Intervinientes</th><th></th></tr></thead>
                <tbody></tbody>
            </table>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-dismiss="modal">Cancelar</button>
        </div>
    </div>
</div>
