<h2 class="form_title">Comienza a invertir seleccionando uno de nuestros productos</h2>

<div data-selecttitle="Elige un producto" class="form_block boxes" data-bind="css:{ 'selected':vm.ProductModel().ProductType()!=undefined }">
    @*<!-- ko if: $index() === 0 -->
        <span class="label"></span>
        <!-- /ko -->*@
    <div class="radio_box-container" data-bind="foreach: ProductTypeList">
        <!-- ko if: !vm.hasOwnProperty('CurrentStep') || Id()!='4' || (vm.hasOwnProperty('UserCRII') && !vm.UserCRII()) || !sessionStorage.getItem('birthday') -->
        <div class="form_block-content radio_box small_block" data-bind="event:{change:$root.ProductModel().ResetAge}">
            <input type="radio" name="typeproduct" data-bind="attr: {value: Id , id: 'product-type' + Id(), 'data-relative': (Id()!='4' || Products().length<3 ? 'product-content-' + Id():'epsv-content')}, checked: $parent.ProductType" />
            <label data-bind="attr: {for: 'product-type' + Id()}" class="radio_box-label">
                <i class="label_icon">
                    <svg width="19" height="17" viewBox="0 0 19 17" xmlns="http://www.w3.org/2000/svg">
                        <g stroke="#B59971" stroke-width="2.25" fill="none" fill-rule="evenodd" stroke-linecap="square">
                            <path d="M2.289 9.273l4.498 5.51M6.742 14.727L17.426 1.64"></path>
                        </g>
                    </svg>
                </i>
                <i class="block_icon" data-bind="html: svgfile">
                </i>
                <h4 data-bind="text: Name" class="title"></h4><span data-bind="html: Description" class="text"></span>
            </label>
        </div>
        <!-- /ko -->
    </div>
</div>


<div id="epsv-content" class="form_block boxes" style="display: none;" data-bind="css:{ 'selected': sessionStorage.getItem('lifeCicleOK')!='null' && sessionStorage.getItem('lifeCicleOK')!=null }">
    <span class="label">Solo para ahorradores con residencia fiscal en el país vasco.</span>
    <p class="mini_text">De acuerdo con la normativa vigente en el País Vasco, BESTINVER Individual EPSV te ofrece la posibilidad de adherirte a una estrategia de inversión de Ciclo de Vida que se desarrolla a través de tres Planes de Previsión con diferentes combinaciones de riesgo y rentabilidad. Esta estrategia te asignará, en función de tu edad, un plan de previsión concreto. Es necesario que leas la estrategia que BESTINVER ha desarrollado antes de continuar:</p>
    <a title="Descargar los documentos" id="life_cycle_download" class="link brown darken icon left">
        <i>
            <svg width="14" height="16" viewBox="0 0 14 16" xmlns="http://www.w3.org/2000/svg">
                <g fill-rule="nonzero" fill="#B59971">
                    <path d="M13.25 13.929v1.383H.75V13.93h12.5zM7.585 9.286l2.774-2.779h.211l.645.633.001.213-4.11 4.11-.21.001-4.2-4.11-.001-.214.645-.634h.21l2.835 2.798V1l.15-.15h.9l.15.15v8.286z"></path>
                </g>
            </svg>
        </i><span>Estrategia de inversión de ciclo de vida de BESTINVER INDIVIDUAL EPSV</span>
    </a>
    <p class="mini_text">Puedes empezar a invertir seleccionando uno de nuestros tres Planes de Previsión Social Individual o adherirte a la estrategia de inversión de Ciclo de Vida. Elige la opción que deseas: </p>
    <div class="radio_box-container">
        <!-- adherir-->
        <div class="form_block-content radio_box big_block form_block-content-check">
            <input name="adhesion" data-relative="adhere_content_date" id="adhere" type="radio" data-bind="event:{change:$root.ProductModel().Accept}">
            <label for="adhere" class="noBorder"><i class="icon"></i><span class="text">He leído la estrategia de inversión de ciclo de vida y&nbsp;<strong>he decidido adherirme.&nbsp;</strong>Por tanto, en función de mi edad se me asignará automáticamente el Plan de Previsión Social Individual que me corresponda.</span></label>
        </div>
        <!-- custom content : from adhere --> insert date--&gt;
        <div id="adhere_content_date" class="form_block boxes" style="display: none;">
            <!-- insert date-->


            <div class="form_block-content date">
                <label for="personaldata-birthday-day">
                    <span>Fecha de nacimiento</span><span class="optional">(dd/mm/aaaa)</span>
                </label>
                <input type="text" class="input-integer-2 numonly" placeholder="dd" max="31" min="1" name="personaldata-birthday-day" id="personaldata-birthday-day"
                       data-bind="value: LifeCicleDate().Day">
                <input type="text" class="input-integer-2 numonly" placeholder="mm" max="12" min="1" name="personaldata-birthday-month" id="personaldata-birthday-month"
                       data-bind="value: LifeCicleDate().Month">
                <input type="text" class="input-integer-4 numonly birthyear" placeholder="aaaa" max="9999" min="1900" name="personaldata-birthday-year" id="personaldata-birthday-year"
                       data-bind="value: LifeCicleDate().Year">
                <span class="error_message" data-bind="text: $root.ProductModel().LifeCicleDate.error(), visible: $root.ProductModel().LifeCicleDate.error()!=''"></span>
            </div>

            <!-- button-->
            <div class="form_block-content buttons small">
                <div data-relative="product-content-4" class="button_next" data-bind="click: LifeCicleClick"><a title="enviar tu data de nacimiento" class="button brown toWhite"><span>Mostrar plan</span></a></div>
            </div>
        </div>
        <!-- deny-->
        <div class="form_block-content radio_box big_block form_block-content-check">
            <input name="adhesion" data-relative="product-content-4" id="deny" type="radio" data-bind="event:{change:$root.ProductModel().Deny}">
            <label for="deny" class="noBorder"><i class="icon"></i><span class="text">He leído la estrategia de inversión de ciclo de vida y&nbsp;<strong>he decido no adherirme.&nbsp;</strong>Deseo elegir el Plan de Previsión Social Individual en el que invertir.</span></label>
        </div>
    </div>

</div>
<div class="index-products" data-bind="foreach: ProductTypeList">

    <div class="form_block boxes hidden" data-bind="attr: {id: 'product-content-' + Id()}, css:{ 'selected':vm.ProductModel().Product()!=undefined,'margintop-60':Products().length>=3 && $root.ProductModel().ProductType() == '4'}">

        <span class="label" data-bind="text: Name, visible: $root.ProductModel().ProductType() != '4'"></span>
        <span class="mini_text" data-bind="visible: $root.ProductModel().ProductType() == '4' && $root.ProductModel().LifeCicleAge()">Según nuestra estrategia de ciclo de vida, te corresponde invertir en:</span>
        <span class="mini_text" data-bind="visible: $root.ProductModel().ProductType() == '4' && !$root.ProductModel().LifeCicleAge()">Elige tu plan:</span>

        <div class="radio_box-container" data-bind="foreach: Products()">
            <!-- ko if: $root.ProductModel().ProductType()!='4' || !$root.ProductModel().LifeCicleAge() || (FromAge()<=$root.ProductModel().LifeCicleAge() && $root.ProductModel().LifeCicleAge()< ToAge()) -->
            <div class="form_block-content radio_box small_block" data-bind="attr:{ 'data-from-age': FromAge(),'data-to-age': ToAge(),id: 'productId-' + Id() }">

                <input type="radio" data-bind="attr: {value: Id , id: 'product' + Id() , name: 'product-type' + ProductTypeId() }, checked: $root.ProductModel().Product"
                       onclick="window.scrollWindow('btn-select-product');">
                <label class="radio_box-label" data-bind="attr: {for: 'product' + Id()}">

                    <i class="label_icon">
                        <svg width="19" height="17" viewBox="0 0 19 17" xmlns="http://www.w3.org/2000/svg">
                            <g stroke="#B59971" stroke-width="2.25" fill="none" fill-rule="evenodd" stroke-linecap="square">
                                <path d="M2.289 9.273l4.498 5.51M6.742 14.727L17.426 1.64"></path>
                            </g>
                        </svg>
                    </i>
                    <h4 class="title">
                        <span data-bind="text: Name"></span>
                    </h4>
                    <span class="text">
                        <span data-bind="html: Description"></span>
                    </span><span class="footer"><span data-bind="html: Profitability()" class="perc"></span><span class="footer_text" data-bind="html: ProfitabilityDateText()"></span></span>
                </label>
            </div>
            <!-- /ko -->
        </div>
        <div class="form_block-content big product_help">
            <span class="mini_text" data-bind="html: $root.ProductModel().ProfitabilityDate"></span>
            <!-- ko if: $root.ProductModel().ProfitabilityDateFIL()!='' -->
            <span class="mini_text" data-bind="html: $root.ProductModel().ProfitabilityDateFIL"></span>
            <!-- /ko -->
            <span class="mini_text" data-bind="html: $root.ProductModel().ProfitabilityDisclaimer"></span>
        </div>

    </div>
</div>

<script type="text/javascript">


    function buildPdfEpsvHref() {
        var MobileData = Utils.GetMobileAppData();
        var isBstapp = MobileData.AppVersion && (MobileData.AppVersion.indexOf("bstapp") != -1 || MobileData.AppVersion.indexOf("bestinver") != -1);
        if (isBstapp) {
            $("#life_cycle_download").attr('href', "#");
            $("#life_cycle_download").on("click", function () {
                generateB64Document('@Url.Action("download","site", new { id = "Estrategia ciclo de vida.pdf" })' + '?isBase64=true', false, false)
            });
        } else {
            $("#life_cycle_download").attr('href', `@Url.Action("download", "site", new { id="Estrategia ciclo de vida.pdf" })`);
        }
    }

    function generateB64Document(url, newTab, concatBstapp) {
        $.ajax({
            url: url,
            success: function (b64String) {
                downloadDocumentUrl(b64String, concatBstapp);
            },
            error: function (jqXHR, textStatus, errorThrown) { console.log(textStatus) },
        });
    }

    function windowOpenDocumentUrl(b64String, concatBstapp) {
        window.open("data:application/pdf;base64, " + b64String + concatBstapp ? '#bstapp' : '');
    }

    function downloadDocumentUrl(b64String, concatBstapp) {
        var pdfByte = base64ToArrayBuffer(b64String);
        createBlobFromByte('Estrategia ciclo de vida.pdf', pdfByte, concatBstapp);
    }

    function base64ToArrayBuffer(base64) {
        var binaryString = window.atob(base64);
        var binaryLen = binaryString.length;
        var bytes = new Uint8Array(binaryLen);
        for (var i = 0; i < binaryLen; i++) {
            var ascii = binaryString.charCodeAt(i);
            bytes[i] = ascii;
        }
        return bytes;
    }

    function createBlobFromByte(pdfName, byte, concatBstapp) {
        var blob = new Blob([byte], { type: "application/pdf" });
        var link = document.createElement('a');
        link.href = window.URL.createObjectURL(blob);
        link.href = link.href + `${concatBstapp ? '#bstapp' : ''}`
        link.target = '_blank'
        link.setAttribute('download', `${pdfName}.pdf`)
        document.body.appendChild(link)
        link.click()
        document.body.removeChild(link)
    };

    function goHomeBstapp() {
        var timeouturl = '@(Url.Action("SessionExpiredError", "Error", null))';
        location.href = timeouturl;
    }

    $(document).ready(function () {
        buildPdfEpsvHref();
    });
</script>