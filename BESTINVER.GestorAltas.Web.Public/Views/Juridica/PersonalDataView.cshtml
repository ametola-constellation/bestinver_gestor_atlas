@using Newtonsoft.Json;

@model BESTINVER.GestorAltas.Web.Public.Models.Register.PersonalDataViewModel

@{
    ViewBag.Title = "PersonalDataView";
    Layout = "~/Views/Shared/_Layout_Juridico.cshtml";
}

@Html.AntiForgeryToken()

@{
    int milliseconds = (int)Model.SessionTimeout * 60 * 1000;
}

@section scripts{

    <script language="javascript" type="text/javascript">

        $.blockUI.defaults.css.cursor = "dafault";
        $.blockUI.defaults.css.backgroundColor = "#fff";
        $.blockUI.defaults.overlayCSS.cursor = "default";
        $.blockUI.defaults.overlayCSS.backgroundColor = "#fff";

        var timeoutfnc;
        var timeouturl = '@(Url.Action("SessionExpiredError", "Error", null))';
        var internalerrorurl = '@(Url.Action("InternalError", "Error", null))';
        var timeoutcheck = false;
        var parser = new UAParser();

        function InitTimeoutFnc() {
            timeoutfnc = setTimeout(function () {
                timeoutcheck = true;
            },
                @milliseconds.ToString()
            );
        }
        function ResetTimeoutFnc() {
            clearTimeout(timeoutfnc);
            timeoutfnc = setTimeout(function () {
                timeoutcheck = true;
            },
                @milliseconds.ToString()
            );
        }


        var ProductID = '@Model.ProductID';
        var ProductTypeID = '@Model.ProductTypeID';
        var username = '@Html.Raw(Model.UserName)';
        var usermail = '@Html.Raw(Model.UserMail)';
        var ismobile = '@Html.Raw(Model.IsMobile).ToString().ToLower()';
        var modal = '@Model.Modal';
        var IsAuthenticated = '@User.Identity.IsAuthenticated.ToString().ToLower()' == 'true';
        var ProductModel = @Html.Raw(JsonConvert.SerializeObject(Model.Product));
        var CurrentProduct;

        if (ProductID != undefined && ProductID.trim() != "") {
            CurrentProduct = new Product(ProductModel.Id, ProductModel.ProductTypeId, ProductModel.Name, ProductModel.Description, ProductModel.Profitability, ProductModel.ProfitabilityDateText, ProductModel.IdOperation, ProductModel.AdultMax, ProductModel.AdultMin, ProductModel.MinorMax, ProductModel.MinorMin, ProductModel.DisabledMax, ProductModel.DisabledMin, ProductModel.IBAN, ProductModel.FromAge, ProductModel.ToAge, ProductModel.ComplexProduct, ProductModel.RDCode, ProductModel.Family, ProductModel.EmployeeMax, ProductModel.EmployeeMin, ProductModel.SubFamilyProductId);
        } else {
            location.href = 'Index';
        }

        if (username != "") {
            if (usermail.toUpperCase().indexOf('BESTINVER.ES') < 0) {
                var external = username.slice(username.length - 4);
                if (external.toUpperCase() == "_EXT") {
                    validatedomain = false;
                    $('#basicdata-email-comercial').attr('readonly', true);
                }
            }
        }

        var applicant = Utils.GetMainApplicant(CurrentProduct, ApplicantTypeEnum.JURIDICA, 1, IsAuthenticated);
        var vm = new ViewModel(applicant, CurrentProduct);
        var GMT;
        var productslist = @Html.Raw(JsonConvert.SerializeObject(Model.Products));
        var typeproductslist = @Html.Raw(JsonConvert.SerializeObject(Model.ProductTypes));
        var MasterData = new MasterDataModel(ApplicantTypeEnum.JURIDICA, ProductID, ProductTypeEnum.properties[ProductTypeID].value);

        $(document).ready(function () {
            CustomQuestionBehabiors.DOMReady();
            MasterData.setProductList(productslist)
                .then(function () { return MasterData.setProductTypeList(typeproductslist, false) })
                .then(function () {
                    var genders = @Html.Raw(JsonConvert.SerializeObject(Model.MasterData.Genders));
                    var countries = @Html.Raw(JsonConvert.SerializeObject(Model.MasterData.Countries));
                    var nationalities = @Html.Raw(JsonConvert.SerializeObject(Model.MasterData.Nationalities));
                    var viatypes = @Html.Raw(JsonConvert.SerializeObject(Model.MasterData.ViaTypes));
                    var provinces = @Html.Raw(JsonConvert.SerializeObject(Model.MasterData.Provinces));
                    var sendingways = @Html.Raw(JsonConvert.SerializeObject(Model.MasterData.SendingWays));
                    var receivingways = @Html.Raw(JsonConvert.SerializeObject(Model.MasterData.ReceivingWays));
                    var documentsendingways = @Html.Raw(JsonConvert.SerializeObject(Model.MasterData.DocumentSendingWays));
                    var signaturetypes = @Html.Raw(JsonConvert.SerializeObject(Model.MasterData.SignatureTypes));

                    MasterData.setGender(genders);
                    MasterData.setViaType(viatypes);
                    MasterData.setSignatureType(signaturetypes);
                    MasterData.setSendingWay(sendingways);
                    MasterData.setReceivingWay(receivingways);
                    MasterData.setDocumentSendingWay(documentsendingways);
                    MasterData.getOperationType();
                    MasterData.setProvinces(provinces);
                    MasterData.setCountry(countries);
                    MasterData.setNationality(nationalities);
                    MasterData.getQuestionCollection();

                    vm.Init(IsAuthenticated, username, usermail, MasterData.ProductTypeList());

                    if (location.hash == '#BasicData') {
                        Navigation.ShowNextStep(location.hash.split('#')[1]);
                    } else {
                        location.hash = '#BasicData';
                    }

                    ko.applyBindings(vm);
                    bindAutocomplete();
                    initAutocomplete();
                    InitInvestmentAutocomplete(ProductTypeID);

                    if (modal == 'S') {
                        setTimeout(function () {
                            window.launchAjax(routeConfig.GA_Register_PopPup_popup_cta_access);
                        }, 1000);
                    }

                    window.SetCleaveClass();
                    InitTimeoutFnc();

                });          
        });

    </script>
}

@{ await Html.RenderPartialAsync("_RegistrationHeader"); }

<div class="registration_resume" style="height: 1496px;" data-bind="with: vm">
    @{ await Html.RenderPartialAsync("_Resume"); }
</div>

<div class="registration_form">
    <div class="registration_inner" id="personal-data-content">
        <h2 id="basic-data-head" class="form_title">1. Datos personales</h2>
        <ul id="personal-data-content-steps" class="form_steps-list">

            <li id="basicdata-content-head" class="form_steps-list_element hidden" data-circle="1" data-progress="25" data-step="BasicData">
                <h3 class="form_steps-title">
                    Datos de la sociedad

                </h3>
                <div id="basicdata-content" class="form_block hidden" data-bind="with: vm">
                    @{ await Html.RenderPartialAsync("_BasicDataView"); }
                </div>
            </li>

            <li id="personaldata-content-head" class="form_steps-list_element hidden" data-circle="1" data-progress="50" data-step="PersonalData">
                <div id="personaldata-content" class="form_block hidden" data-bind="with: vm">
                </div>
            </li>

            <li id="personaldata-address-content-head" class="form_steps-list_element hidden" data-circle="1" data-progress="75" data-step="ContactData">
                <h3 class="form_steps-title">
                    Dirección de contacto de la sociedad
                    <button class="form_steps-edit_button link brown darken" data-bind="click:function () { Navigation.EditData(2, this, 'ContactData'); }">
                        <span>Editar</span>
                    </button>
                </h3>
                <div id="contactdata-content" class="form_block hidden" data-bind="with: vm">
                    @{ await Html.RenderPartialAsync("_ContactView"); }
                </div>
            </li>

            <li id="apoderado-content-head" class="form_steps-list_element hidden" data-circle="1" data-progress="75" data-step="AgentData">
                <h3 class="form_steps-title" id="other-applicant-title-6">
                    Apoderados
                    <button class="form_steps-edit_button link brown darken" data-bind="click:function () { Navigation.EditData(3, this, 'AgentData'); }">
                        <span>Editar</span>
                    </button>
                </h3>
                <div id="apoderado-content" class="form_block hidden" data-bind="with: vm">
                    @{
                        var cotitularModel = new OtherApplicantModel
                        {
                            ApplicantRequestType = "6",
                            ApplicantRequestName = "apoderado"
                        };
                    }
                    <partial name="_OtherApplicantView" model="cotitularModel" />
                </div>
            </li>
        </ul>
    </div>

    <div class="registration_inner hidden" id="investment-content" data-bind="with: vm" data-circle="2" data-progress="0" data-step="OperationData">
        @{ await Html.RenderPartialAsync("Operation/_CriiOperationView"); }
    </div>

    <div class="registration_inner hidden" id="investment-iban-content" data-bind="with: vm, attr: { 'data-progress': dataProgressStep2 }" data-circle="2" data-progress="50" data-step="OperationIbanAssistedData">
        @{ await Html.RenderPartialAsync("Operation/_OperationIbanView"); }
    </div>

    <div class="registration_inner hidden" id="test-content" data-bind="with: vm" data-circle="3" data-progress="0" data-step="TestData">
        @{ await Html.RenderPartialAsync("_TestView"); }
    </div>

    <div id="documents-content" class="registration_inner hidden">
        <h2 id="signature-head" class="form_title">4. Firma de documentación</h2>

        <ul class="form_steps-list">

            <li id="signature-content-head" class="form_steps-list_element hidden" data-circle="4" data-progress="25" data-step="SignatureData"
                data-bind="with: vm">
                <h3 class="form_steps-title">
                    Firma de la documentación
                </h3>
                <div id="signature-content" class="form_block hidden" data-bind="with: SignatureData">
                    @{ await Html.RenderPartialAsync("Documents/_SignatureView"); }
                </div>

                <div id="signature-content-download" class="form_block hidden">
                    @{ await Html.RenderPartialAsync("Documents/_SignatureDocumentDownloadView"); }
                </div>

                <div id="signature-content-post" class="form_block hidden">
                    @{ await Html.RenderPartialAsync("Documents/_SignatureDocumentPostView"); }
                </div>

            </li>



            <li id="signature-document-content-head" class="form_steps-list_element hidden" data-circle="4" data-progress="50" data-step="SignatureDocumentData">
                <h3 class="form_steps-title">
                    Envío de documentación
                </h3>
                <div id="signature-document-content" class="form_block hidden" data-bind="with: vm">
                    @{ await Html.RenderPartialAsync("Documents/_SignatureDocumentView"); }
                </div>
            </li>

            <li id="applicant-document-content-head" class="form_steps-list_element hidden" data-circle="4" data-progress="75" data-step="DocumentData">
                <h3 class="form_steps-title">
                    Envío de documentación del titular
                </h3>
                <div id="applicant-document-content" class="form_block hidden" data-bind="with: DocumentsData">
                    @{ await Html.RenderPartialAsync("Documents/_DocumentView"); }
                </div>
            </li>

        </ul>

    </div>

    <div id="success-content" class="registration_inner hidden" data-bind="with: vm" data-circle="5" data-progress="100" data-step="Success">
        <h3 class="form_steps-title">
            Finalización del proceso
        </h3>
        @{ await Html.RenderPartialAsync("_SuccessView"); }
    </div>

    <div id="error-content" class="registration_inner hidden" data-bind="with: vm" data-circle="0" data-progress="0" data-step="Error">
        @{ await Html.RenderPartialAsync("_ErrorView"); }
    </div>

</div>